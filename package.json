{
  "name": "@chocbite/ts-supplement-eslint",
  "version": "1.0.2",
  "description": "ESLint definitions for chocbite TypeScript projects",
  "author": "chocolateandmilkwin",
  "license": "MIT",
  "type": "module",
  "private": false,
  "module": "./dist/eslint.config.js",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/eslint.config.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "upgrades": "npx npm-check-updates --target semver",
    "upgrade": "npx npm-check-updates --target semver -u && npm install"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "eslint": "^10.2.0",
    "typescript-eslint": "^8.58.2"
  }
}
